{
  "manifest_version": 3,
  "name": "Fluxo Web3 Wallet",
  "version": "0.2.0",
  "description": "Open-source non-custodial Web3 wallet extension powered by a Go WebAssembly core.",
  "action": {
    "default_title": "Fluxo Web3 Wallet",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
