{
  "manifest_version": 3,
  "name": "Go Web3 Wallet",
  "version": "0.1.0",
  "description": "Minimal local-first Ethereum wallet extension powered by a Go WebAssembly core.",
  "action": {
    "default_title": "Go Web3 Wallet",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
